# =============================================================================
# NAS Upload Configuration — DeJager Cohort (Transcriptomics)
# =============================================================================
# Sourced by upload_to_nas.sh and download_from_nas.sh.
# Edit values here rather than in the scripts themselves.
# =============================================================================

# --- Local data paths --------------------------------------------------------
# REPO_ROOT is set by config/paths.sh; do not hard-code it here.
LOCAL_BASE="${REPO_ROOT}/Data/Transcriptomics/DeJager"

# --- SFTP connection ---------------------------------------------------------
REMOTE_HOST="tsailabnas.mit.edu"
SFTP_PORT=22
SFTP_USER="mabdel03"
SFTP_AUTHFILE="${HOME}/.smb_tsailabnas"

# --- Remote NAS path (inside SFTP chroot: /LabShared is the root) ------------
SFTP_REMOTE_BASE="/LabShared/mabdel03/ROSMAP/Data/Transcriptomics/DeJager"

# --- SFTP tuning -------------------------------------------------------------
SFTP_NUM_REQUESTS=64
SFTP_CIPHER="aes128-gcm@openssh.com"
SFTP_BUFFER_SIZE=""   # empty = default 32KB; do NOT increase

# --- Sharding (for SLURM array parallelism) ----------------------------------
# Override via environment variables (e.g., in slurm_upload.sh).
SFTP_SHARD_TOTAL="${SFTP_SHARD_TOTAL:-1}"
SFTP_SHARD_INDEX="${SFTP_SHARD_INDEX:-0}"

# --- Data types to transfer --------------------------------------------------
DATA_TYPES="${DATA_TYPES:-FASTQs Cellranger_Output Cellbender_Output}"

# --- State tracking ----------------------------------------------------------
STATE_DIR="${HOME}/.nas_transfer_state"
