# =============================================================================
# NAS Upload Configuration — DeJager Cohort (Processing Outputs)
# =============================================================================
# Sourced by upload_processing_outputs_to_nas.sh and
# download_processing_outputs_from_nas.sh.
# Edit values here rather than in the scripts themselves.
# =============================================================================

# --- Local data paths --------------------------------------------------------
# REPO_ROOT is set by config/paths.sh; do not hard-code it here.
LOCAL_BASE="${REPO_ROOT}/Data/Transcriptomics/DeJager/Processing_Outputs"

# --- SFTP connection ---------------------------------------------------------
REMOTE_HOST="tsailabnas.mit.edu"
SFTP_PORT=22
# NAS_SFTP_USER is set in config/paths.sh (defaults to $USER)
SFTP_USER="${NAS_SFTP_USER:-${USER}}"
SFTP_AUTHFILE="${HOME}/.smb_tsailabnas"

# --- Remote NAS path (inside SFTP chroot: /LabShared is the root) ------------
# NAS remote path — update if your NAS directory differs from the default
SFTP_REMOTE_BASE="/LabShared/${NAS_SFTP_USER:-${USER}}/ROSMAP/Data/Transcriptomics/DeJager/Processing_Outputs"

# --- SFTP tuning -------------------------------------------------------------
SFTP_NUM_REQUESTS=64
SFTP_CIPHER="aes128-gcm@openssh.com"
SFTP_BUFFER_SIZE=""   # empty = default 32KB; do NOT increase

# --- Data types to transfer --------------------------------------------------
# Subdirectories within Processing_Outputs/ to transfer.
# Override via environment variable to transfer only specific stages.
DATA_TYPES="${DATA_TYPES:-01_QC_Filtered 02_Doublet_Removed 03_Integrated}"

# --- Sharding (for SLURM array parallelism) ----------------------------------
SFTP_SHARD_TOTAL="${SFTP_SHARD_TOTAL:-1}"
SFTP_SHARD_INDEX="${SFTP_SHARD_INDEX:-0}"

# --- State tracking ----------------------------------------------------------
STATE_DIR="${HOME}/.nas_transfer_state"
