#   export CELLRANGER_REF="/om2/user/${USER}/references/refdata-gex-GRCh38-2020-A"
#   export DEJAGER_WGS_DIR="/om/scratch/Mon/shared_folder/WGS"
#   export SLURM_PARTITION_GPU="mit_normal_gpu"
